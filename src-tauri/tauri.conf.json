{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PersonaDesk",
  "version": "0.1.0",
  "identifier": "com.personadesk.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PersonaDesk",
        "width": 1280,
        "height": 820,
        "minWidth": 960,
        "minHeight": 680
      },
      {
        "label": "companion",
        "title": "PersonaDesk Companion",
        "url": "index.html?surface=companion",
        "width": 280,
        "height": 360,
        "minWidth": 240,
        "minHeight": 300,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
